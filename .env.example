# Core
NODE_ENV=development
APP_ENV=local
APP_TIMEZONE=Asia/Dhaka
API_PORT=3000
PUBLIC_API_URL=http://localhost:3000
PUBLIC_WS_URL=ws://localhost:3000/ws
CORS_ORIGINS=http://localhost:5173

# Neon
DATABASE_URL=postgresql://user:password@host/officepulse?sslmode=require
DATABASE_DIRECT_URL=postgresql://user:password@host/officepulse?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=officepulse

# Platform PIN access and control re-verification
PLATFORM_PIN_HASH=
PLATFORM_SESSION_TTL_SECONDS=28800
PLATFORM_IDLE_TIMEOUT_SECONDS=1800
CONTROL_REAUTH_TTL_SECONDS=300
SESSION_COOKIE_SECRET=

# Discord
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ALERT_CHANNEL_ID=
DISCORD_COMMAND_CHANNEL_ID=
DISCORD_ALLOWED_CONTROL_USER_IDS=

# AI provider
AI_PROVIDER=groq
AI_API_KEY=
AI_MODEL=
AI_MAX_TOOL_ROUNDS=6
AI_CONVERSATION_TTL_DAYS=30

# Energy and rules
DEFAULT_TARIFF_PER_KWH=
CURRENCY=BDT
CARBON_KG_PER_KWH=
OFFICE_OPEN_TIME=09:00
OFFICE_CLOSE_TIME=17:00
PIR_RECENT_SECONDS=120
PIR_VACANT_SECONDS=900
SHUTDOWN_WARNING_SECONDS=120
TELEMETRY_STALE_SECONDS=90

# Internal services
INTERNAL_SERVICE_TOKEN=
TELEMETRY_HMAC_SECRET=
SIMULATOR_TIME_SCALE=1
